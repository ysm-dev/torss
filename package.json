{
  "name": "torss",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun build --target bun --compile --outfile dist/torss src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "format": "biome format --write .",
    "knip": "knip",
    "lint": "biome check .",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "hono": "^4.12.10",
    "ofetch": "^1.5.1",
    "p-limit": "^7.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260405.1",
    "knip": "^6.3.0"
  }
}
